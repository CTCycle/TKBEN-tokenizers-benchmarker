# =============================================================================
# Network: backend listener
# =============================================================================
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=5000
TKBEN_ALLOW_UNAUTHENTICATED_NETWORK_BIND=false

# =============================================================================
# Network: frontend listener and API base path
# =============================================================================
UI_HOST=127.0.0.1
UI_PORT=8000
VITE_API_BASE_URL=/api

# =============================================================================
# Runtime behavior
# =============================================================================
RELOAD=false
OPTIONAL_DEPENDENCIES=true

# =============================================================================
# Database: mode selection
# =============================================================================
DATABASE_EMBEDDED=true

# =============================================================================
# Database: connection settings
# DATABASE_URL is optional. When set, it seeds the engine/host/port/name/user/
# password values below. Explicit DATABASE_* fields still take precedence.
# =============================================================================
DATABASE_URL=
DATABASE_ENGINE=postgresql+psycopg
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=app
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change-me
DATABASE_SSL=false
DATABASE_SSL_CA=

# =============================================================================
# Database: runtime tuning
# =============================================================================
DATABASE_CONNECT_TIMEOUT=30
DATABASE_INSERT_BATCH_SIZE=1000

# =============================================================================
# AI and rendering
# =============================================================================
KERAS_BACKEND=tensorflow
MPLBACKEND=Agg

# =============================================================================
# Security
# =============================================================================
ALLOW_KEY_REVEAL=false
HF_KEYS_ENCRYPTION_KEY=replace-with-base64-32-byte-key
