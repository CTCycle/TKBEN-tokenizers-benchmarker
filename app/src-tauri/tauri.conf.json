{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TKBEN Desktop",
  "version": "3.5.0",
  "identifier": "com.tkben.desktop",
  "build": {
    "beforeBuildCommand": "",
    "frontendDist": "../client/dist",
    "devUrl": "about:blank"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TKBEN Desktop",
        "url": "about:blank",
        "width": 1440,
        "height": 920,
        "center": true,
        "resizable": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "r/app/server": "app/server",
      "r/settings": "settings",
      "r/app/client/dist": "app/client/dist",
      "r/app/resources": "app/resources",
      "r/runtimes/python": "runtimes/python",
      "r/runtimes/uv": "runtimes/uv"
    }
  }
}
